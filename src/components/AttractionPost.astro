---
// ─────────────────────────────────────────────────────────────────────────
// AttractionPost — reusable layout for landmark/attraction articles.
// Used by Flying Horse Carousel, Lighthouse, Napatree, Misquamicut, etc.
// Each article is a thin data file that imports this component.
// ─────────────────────────────────────────────────────────────────────────

interface QuickFact { label: string; value: string; }
interface TipSection { label: string; body: string; }
interface Faq { q: string; a: string; }
interface Related { href: string; tag: string; title: string; }

interface Props {
  // Hero
  kicker: string;
  title: string;          // Article H1 (supports an <em> with one phrase wrapped)
  titleEm?: string;       // Optional emphasis phrase highlighted in the H1
  titleTail?: string;     // Optional text after the emphasized phrase
  subtitle: string;
  readingTime: string;

  // The verdict / lede
  verdict: string;        // Short answer or core take in 1–2 sentences

  // Story sections
  introParagraphs: string[];           // Lede + 1–2 body paragraphs (the "story")
  quickFacts: QuickFact[];             // ~6 fast-reference facts
  tips: TipSection[];                  // 3–5 practical tips (open hours, parking, etc)
  history?: string[];                  // Optional historical paragraphs

  // Affiliate CTA (optional, when relevant)
  cta?: {
    label: string;     // "Browse stays near Watch Hill →"
    url: string;       // Affiliate URL
    framing: string;   // 1-sentence context for the CTA
  };

  faqs: Faq[];
  related: Related[];
}

const {
  kicker,
  title,
  titleEm,
  titleTail,
  subtitle,
  readingTime,
  verdict,
  introParagraphs,
  quickFacts,
  tips,
  history,
  cta,
  faqs,
  related,
} = Astro.props;
---

<article class="article">
  <!-- Hero -->
  <header class="hero">
    <div class="hero-inner">
      <p class="kicker">{kicker}</p>
      <h1>
        {title}
        {titleEm && <em>{titleEm}</em>}
        {titleTail}
      </h1>
      <p class="hero-sub">{subtitle}</p>
      <div class="meta">
        <span>Updated May 26, 2026</span>
        <span class="dot">·</span>
        <span>{readingTime}</span>
        <span class="dot">·</span>
        <span>Written from Westerly, RI</span>
      </div>
    </div>
  </header>

  <!-- Verdict -->
  <section class="verdict">
    <div class="v-inner">
      <p class="v-label">The Short Answer</p>
      <p class="v-text" set:html={verdict} />
    </div>
  </section>

  <!-- Quick Facts -->
  <section class="facts">
    <p class="facts-label">Quick Facts</p>
    <dl class="facts-grid">
      {
        quickFacts.map((f) => (
          <div>
            <dt>{f.label}</dt>
            <dd>{f.value}</dd>
          </div>
        ))
      }
    </dl>
  </section>

  <!-- Intro Story -->
  <section class="prose">
    {
      introParagraphs.map((p, i) => (
        <p class={i === 0 ? "lede" : ""} set:html={p} />
      ))
    }
  </section>

  <!-- Optional History -->
  {
    history && history.length > 0 && (
      <section class="prose">
        <h2 class="section-h">The History</h2>
        {history.map((p) => <p set:html={p} />)}
      </section>
    )
  }

  <!-- Practical Tips -->
  <section class="tips">
    <h2 class="section-h">What to Know Before You Go</h2>
    <div class="tips-list">
      {
        tips.map((t) => (
          <div class="tip">
            <p class="tip-label">{t.label}</p>
            <p set:html={t.body} />
          </div>
        ))
      }
    </div>
  </section>

  <!-- Optional CTA -->
  {
    cta && (
      <section class="cta">
        <div class="cta-inner">
          <p class="cta-framing">{cta.framing}</p>
          <a class="cta-btn" href={cta.url} rel="sponsored nofollow">
            {cta.label}
          </a>
        </div>
      </section>
    )
  }

  <!-- FAQ -->
  <section class="faq">
    <h2 class="section-h">Frequently Asked Questions</h2>
    {
      faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <p>{f.a}</p>
        </details>
      ))
    }
  </section>

  <!-- Related -->
  <section class="related">
    <h2 class="section-h">Keep Reading</h2>
    <div class="related-grid">
      {
        related.map((r) => (
          <a href={r.href} class="related-card">
            <p class="related-tag">{r.tag}</p>
            <h3>{r.title}</h3>
          </a>
        ))
      }
    </div>
  </section>
</article>

<style>
  :root {
    --ink: #1a1d24;
    --ink-soft: #4a5061;
    --ink-muted: #7a8195;
    --paper: #fbf8f1;
    --paper-warm: #f3ede0;
    --line: #e5dfd0;
    --accent: #2c5f5d;
    --accent-deep: #1d3f3d;
    --gold: #b8924a;
    --font-display: "Fraunces", Georgia, serif;
    --font-body: "Inter Tight", -apple-system, system-ui, sans-serif;
  }

  .article {
    background: var(--paper);
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 18px;
    line-height: 1.7;
    padding-bottom: 6rem;
  }
  .article *, .article *::before, .article *::after { box-sizing: border-box; }

  /* HERO */
  .hero {
    background: linear-gradient(180deg, var(--paper-warm) 0%, var(--paper) 100%);
    padding: 5rem 1.5rem 3rem;
    border-bottom: 1px solid var(--line);
  }
  .hero-inner { max-width: 760px; margin: 0 auto; }
  .kicker {
    font-size: 0.8rem; letter-spacing: 0.18em; text-transform: uppercase;
    color: var(--accent); font-weight: 600; margin: 0 0 1.5rem;
  }
  h1 {
    font-family: var(--font-display);
    font-size: clamp(2.2rem, 5.5vw, 4rem);
    line-height: 1.04; letter-spacing: -0.025em; font-weight: 600;
    margin: 0 0 1.5rem;
  }
  h1 em { font-style: italic; color: var(--accent); }
  .hero-sub {
    font-size: 1.2rem; line-height: 1.55; color: var(--ink-soft);
    margin: 0 0 2rem; max-width: 620px;
  }
  .meta {
    display: flex; flex-wrap: wrap; gap: 0.6rem;
    font-size: 0.85rem; color: var(--ink-muted);
  }
  .dot { color: var(--line); }

  /* VERDICT */
  .verdict { max-width: 760px; margin: -1px auto 0; padding: 0 1.5rem; }
  .v-inner {
    background: var(--accent); color: var(--paper);
    padding: 2rem 2.25rem; border-radius: 6px; border-left: 4px solid var(--gold);
  }
  .v-label {
    font-size: 0.72rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--gold); font-weight: 700; margin: 0 0 0.85rem;
  }
  .v-text {
    font-family: var(--font-display);
    font-size: clamp(1.05rem, 2vw, 1.2rem);
    line-height: 1.5; margin: 0; letter-spacing: -0.005em;
    color: rgba(251, 248, 241, 0.95);
  }
  .v-text :global(strong) { color: white; font-weight: 600; }

  /* QUICK FACTS */
  .facts { max-width: 760px; margin: 3rem auto; padding: 0 1.5rem; }
  .facts-label {
    font-size: 0.75rem; letter-spacing: 0.2em; text-transform: uppercase;
    color: var(--ink-muted); font-weight: 600; margin: 0 0 1.25rem;
  }
  .facts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 1.25rem 2rem;
    padding: 1.5rem 1.75rem;
    background: var(--paper-warm);
    border-radius: 4px;
    margin: 0;
  }
  .facts-grid > div {
    min-width: 0;
    border-top: 2px solid var(--line);
    padding-top: 0.6rem;
  }
  .facts-grid dt {
    font-size: 0.68rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--ink-muted); font-weight: 600; margin: 0 0 0.2rem;
  }
  .facts-grid dd {
    margin: 0; font-family: var(--font-display); font-weight: 500;
    font-size: 0.95rem; color: var(--ink); letter-spacing: -0.005em;
    line-height: 1.3;
  }

  /* PROSE */
  .prose { max-width: 680px; margin: 0 auto; padding: 2rem 1.5rem; }
  .prose .lede { font-size: 1.15rem; line-height: 1.7; }
  .prose p { margin: 0 0 1.25rem; color: var(--ink); }
  .prose p:last-child { margin-bottom: 0; }
  .prose :global(strong) { color: var(--ink); font-weight: 600; }
  .prose :global(em) { font-style: italic; }
  .prose :global(a) {
    color: var(--accent); text-decoration: underline;
    text-decoration-thickness: 1px; text-underline-offset: 3px;
  }

  /* HEADINGS */
  .section-h {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    line-height: 1.1; letter-spacing: -0.02em; font-weight: 600;
    margin: 0 0 1.5rem;
  }

  /* TIPS */
  .tips { max-width: 760px; margin: 3rem auto; padding: 0 1.5rem; }
  .tips-list { display: flex; flex-direction: column; gap: 1rem; }
  .tip {
    background: white; border: 1px solid var(--line);
    border-left: 3px solid var(--accent);
    padding: 1.25rem 1.5rem; border-radius: 0 4px 4px 0;
  }
  .tip-label {
    font-family: var(--font-display);
    font-size: 1.05rem; font-weight: 600;
    letter-spacing: -0.01em; color: var(--ink); margin: 0 0 0.4rem;
  }
  .tip p:not(.tip-label) {
    margin: 0; font-size: 0.97rem; color: var(--ink-soft); line-height: 1.6;
  }
  .tip :global(strong) { color: var(--ink); font-weight: 600; }

  /* CTA */
  .cta { max-width: 760px; margin: 3rem auto; padding: 0 1.5rem; }
  .cta-inner {
    background: var(--ink); color: var(--paper);
    padding: 2rem 2.25rem; border-radius: 6px;
    display: flex; flex-direction: column; gap: 1.25rem;
    align-items: flex-start;
  }
  .cta-framing {
    margin: 0; color: rgba(251, 248, 241, 0.85);
    font-size: 1rem; line-height: 1.6; max-width: 540px;
  }
  .cta-btn {
    display: inline-block; background: var(--gold); color: var(--ink);
    padding: 0.8rem 1.5rem; border-radius: 4px; text-decoration: none;
    font-weight: 600; font-size: 0.95rem;
    transition: transform 0.15s ease;
  }
  .cta-btn:hover { transform: translateY(-2px); }

  /* FAQ */
  .faq { max-width: 760px; margin: 3rem auto; padding: 0 1.5rem; }
  .faq-item { border-bottom: 1px solid var(--line); padding: 1.25rem 0; }
  .faq-item summary {
    font-family: var(--font-display);
    font-size: 1.1rem; font-weight: 600; cursor: pointer; color: var(--ink);
    list-style: none; display: flex; justify-content: space-between;
    align-items: center; gap: 1rem; letter-spacing: -0.005em;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary::after {
    content: "+"; font-size: 1.5rem; color: var(--accent);
    font-weight: 400; flex-shrink: 0;
  }
  .faq-item[open] summary::after { content: "−"; }
  .faq-item p {
    margin: 1rem 0 0; color: var(--ink-soft); font-size: 1rem; line-height: 1.6;
  }

  /* RELATED */
  .related {
    max-width: 1080px; margin: 3rem auto 0;
    padding: 3rem 1.5rem 0; border-top: 1px solid var(--line);
  }
  .related-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }
  .related-card {
    display: block; background: white; border: 1px solid var(--line);
    padding: 1.5rem; text-decoration: none; color: var(--ink);
    border-radius: 4px;
    transition: transform 0.2s ease, border-color 0.2s ease;
  }
  .related-card:hover { transform: translateY(-2px); border-color: var(--accent); }
  .related-tag {
    font-size: 0.7rem; letter-spacing: 0.15em; text-transform: uppercase;
    color: var(--accent); font-weight: 600; margin: 0 0 0.75rem;
  }
  .related-card h3 {
    font-family: var(--font-display);
    font-size: 1.15rem; font-weight: 600; margin: 0;
    line-height: 1.25; letter-spacing: -0.01em;
  }

  /* MOBILE */
  @media (max-width: 640px) {
    .hero { padding: 3.5rem 1.25rem 2.5rem; }
    .v-inner { padding: 1.75rem 1.25rem; }
    .facts-grid { padding: 1.25rem 1.5rem; }
    .cta-inner { padding: 1.75rem 1.5rem; }
  }
</style>
