---
const features = [
  {
    num: "01",
    title: "Fast by default",
    body: "Ships zero JavaScript unless you opt in. Lighthouse scores stay green without effort.",
  },
  {
    num: "02",
    title: "Yours to shape",
    body: "Components are plain files. No framework lock-in, no magic to fight.",
  },
  {
    num: "03",
    title: "Deploys anywhere",
    body: "Static output works on Vercel, Netlify, Cloudflare, or a $5 VPS.",
  },
];
---

<section id="features" class="px-6 py-32 border-t border-white/5">
  <div class="max-w-6xl mx-auto">
    <h2 class="font-display text-4xl md:text-5xl font-semibold tracking-tight max-w-2xl mb-20">
      Three reasons it works.
    </h2>
    <div class="grid md:grid-cols-3 gap-12">
      {features.map((f) => (
        <div>
          <div class="font-display text-sm text-neutral-500 mb-4">{f.num}</div>
          <h3 class="text-xl font-medium mb-3">{f.title}</h3>
          <p class="text-neutral-400 leading-relaxed">{f.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
