---
// ─────────────────────────────────────────────────────────────────────────
// FEATURED POST — to feature a different article, edit just this block.
// Everything below is presentation; this is the content.
// ─────────────────────────────────────────────────────────────────────────
const featured = {
  href: "/blog/june-in-watch-hill",
  kicker: "Now Live · Early Summer 2026",
  title: "June in Watch Hill",
  subtitle:
    "The village is fully open, water is warming, and the biggest free cultural event of the year happens on June 20. A local's guide to early summer — including the events worth planning around and why June is the quietly best time to visit before the July peak.",
  meta: [
    "June 20 — Summer Pops at Wilcox Park",
    "Music on the Hill — all month",
    "Lower rates than July & August",
  ],
  readingTime: "9 min read",
};

import NewsletterInline from "./NewsletterInline.astro";

const secondary = [
  {
    href: "/blog/best-things-to-do-in-watch-hill-ri",
    tag: "Start Here",
    title: "15 Best Things to Do in Watch Hill",
  },
  {
    href: "/blog/where-to-stay-watch-hill",
    tag: "Hotel Guide",
    title: "Where to Stay in Watch Hill",
  },
  {
    href: "/blog/watch-hill-vs-newport",
    tag: "Comparison",
    title: "Watch Hill vs Newport: Which to Visit?",
  },
];
---

<section class="hero">
  <div class="hero-shell">
    <div class="hero-grid">
      <div class="hero-text">
        <a href={featured.href} class="featured-link" aria-label={featured.title}>
          <p class="kicker">{featured.kicker}</p>
          <h1 class="hero-title">{featured.title}</h1>
          <p class="hero-sub">{featured.subtitle}</p>

          <ul class="meta-list">
            {featured.meta.map((bullet) => (<li>{bullet}</li>))}
          </ul>

          <p class="hero-cta">
            <span class="cta-text">Read the full guide</span>
            <span class="cta-arrow">→</span>
            <span class="cta-time">· {featured.readingTime}</span>
          </p>
        </a>
      </div>

      <!-- RIGHT: photo collage -->
      <div class="hero-art" aria-hidden="true">
        <!-- Main photo: expansive beach with people and dramatic sky -->
        <div class="art-frame">
          <img
            src="/images/hero-beach-sky.jpg"
            alt="Watch Hill Beach on a clear summer day"
            width="1200"
            height="900"
            loading="eager"
            decoding="async"
          />
        </div>

        <!-- Floating accent card: Ocean House from the beach -->
        <!-- <div class="art-accent">
          <img
            src="/images/hero-ocean-house-beach.jpg"
            alt="The iconic Ocean House hotel seen from the beach"
            width="440"
            height="550"
            loading="eager"
            decoding="async"
          />
          <span class="accent-label">Ocean House · Est. 1868</span>
        </div> -->

        <p class="art-caption">Watch Hill Beach, Rhode Island</p>
      </div>
    </div>

    <div class="secondary">
      <p class="secondary-label">More to explore</p>
      <div class="secondary-grid">
        {secondary.map((post) => (
          <a class="secondary-card" href={post.href}>
            <p class="sc-tag">{post.tag}</p>
            <h3>{post.title}</h3>
            <span class="sc-arrow">Read →</span>
          </a>
        ))}
      </div>
    </div>

    <NewsletterInline />
  </div>
</section>

<style>
  :root {
    --ink: #1a1d24;
    --ink-soft: #4a5061;
    --ink-muted: #7a8195;
    --paper: #fbf8f1;
    --paper-warm: #f3ede0;
    --line: #e5dfd0;
    --accent: #2c5f5d;
    --accent-deep: #1d3f3d;
    --gold: #b8924a;
    --font-display: "Fraunces", Georgia, serif;
    --font-body: "Inter Tight", -apple-system, system-ui, sans-serif;
  }

  .hero {
    background: var(--paper);
    color: var(--ink);
    font-family: var(--font-body);
    padding: 3rem 1.5rem 5rem;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    top: -120px;
    right: -120px;
    width: 480px;
    height: 480px;
    border-radius: 50%;
    background: var(--paper-warm);
    filter: blur(80px);
    opacity: 0.55;
    z-index: 0;
  }
  .hero-shell { max-width: 1200px; margin: 0 auto; position: relative; z-index: 1; }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 4rem;
    align-items: center;
    padding: 3rem 0 5rem;
    border-bottom: 1px solid var(--line);
  }

  .featured-link {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease;
  }
  .featured-link:hover { transform: translateX(2px); }
  .featured-link:hover .cta-arrow { transform: translateX(6px); }

  .kicker {
    font-family: var(--font-body);
    font-size: 0.8rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin: 0 0 1.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .kicker::before {
    content: "";
    width: 28px;
    height: 1px;
    background: var(--gold);
    display: inline-block;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 6vw, 4.75rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
    font-weight: 600;
    margin: 0 0 1.5rem;
    color: var(--ink);
  }

  .hero-sub {
    font-size: clamp(1.05rem, 1.5vw, 1.2rem);
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0 0 2rem;
    max-width: 520px;
  }

  .meta-list {
    list-style: none;
    padding: 0 0 0 1.25rem;
    margin: 0 0 2.5rem;
    border-left: 2px solid var(--gold);
  }
  .meta-list li {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink);
    padding: 0.4rem 0;
    letter-spacing: -0.005em;
  }
  .meta-list li + li { border-top: 1px solid var(--line); }

  .hero-cta {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    margin: 0;
    font-size: 0.92rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--accent);
  }
  .cta-arrow {
    transition: transform 0.2s ease;
    display: inline-block;
    color: var(--accent);
    font-size: 1.1rem;
  }
  .cta-time {
    color: var(--ink-muted);
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: none;
  }

  /* ── ART SIDE ─────────────────────────────────────── */
  .hero-art {
    position: relative;
    width: 100%;
    /* wider cinematic ratio to suit the landscape beach shot */
    aspect-ratio: 4 / 3;
    max-width: 480px;
    justify-self: end;
  }

  /* Main photo frame */
  .art-frame {
    width: 100%;
    height: 100%;
    border-radius: 6px;
    overflow: hidden;
    background: var(--paper-warm);
    box-shadow:
      0 1px 0 rgba(26, 29, 36, 0.06),
      0 18px 50px -20px rgba(26, 29, 36, 0.22);
  }
  .art-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    /* keep the horizon and people in frame */
    object-position: center 60%;
    display: block;
  }

  /* Floating accent card: Ocean House portrait, bottom-left overlap */
  .art-accent {
    position: absolute;
    bottom: 1.25rem;
    left: -1.75rem;
    width: 38%;
    border-radius: 5px;
    overflow: hidden;
    box-shadow:
      0 2px 0 rgba(26, 29, 36, 0.08),
      0 12px 32px -8px rgba(26, 29, 36, 0.32);
    border: 3px solid var(--paper);
    background: var(--paper);
  }
  .art-accent img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center 30%;
    display: block;
  }
  .accent-label {
    display: block;
    padding: 0.4rem 0.6rem;
    font-size: 0.65rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--ink-muted);
    background: var(--paper);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .art-caption {
    position: absolute;
    bottom: -2rem;
    right: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.85rem;
    color: var(--ink-muted);
    margin: 0;
    letter-spacing: -0.005em;
  }

  /* ── SECONDARY STRIP ──────────────────────────────── */
  .secondary { padding: 4rem 0 0; }
  .secondary-label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: 600;
    margin: 0 0 1.5rem;
  }
  .secondary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }
  .secondary-card {
    background: white;
    border: 1px solid var(--line);
    padding: 1.5rem 1.5rem 1.25rem;
    border-radius: 4px;
    text-decoration: none;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, border-color 0.2s ease;
    position: relative;
  }
  .secondary-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
  }
  .secondary-card:hover .sc-arrow { color: var(--accent-deep); }

  .sc-tag {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    margin: 0 0 0.75rem;
  }
  .secondary-card h3 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.015em;
    margin: 0 0 1.25rem;
    flex: 1;
  }
  .sc-arrow {
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--accent);
    transition: color 0.15s ease;
  }

  /* ── MOBILE ───────────────────────────────────────── */
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 2rem 0 3rem;
    }
    .hero-art {
      order: -1;
      max-width: 100%;
      justify-self: stretch;
      aspect-ratio: 16 / 9;
    }
    .art-accent {
      left: auto;
      right: 1rem;
      bottom: 1rem;
      width: 32%;
    }
    .art-caption { position: static; margin-top: 0.6rem; }
  }
  @media (max-width: 640px) {
    .hero { padding: 2rem 1.25rem 3.5rem; }
    .hero-title { font-size: clamp(2.2rem, 9vw, 3rem); }
    .meta-list { padding-left: 1rem; }
    .art-accent { display: none; }
  }
</style>
