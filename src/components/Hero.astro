---

<section class="relative min-h-screen flex items-center px-6 pt-32 pb-20 overflow-hidden">
  <!-- Background accent -->
  <div
    class="absolute -top-40 -right-40 w-[600px] h-[600px] rounded-full blur-3xl opacity-20"
    style="background: var(--color-accent)"
  >
  </div>

  <div class="relative max-w-6xl mx-auto w-full">
    <p class="text-sm uppercase tracking-[0.2em] text-neutral-500 mb-6">
      Now in public beta
    </p>
    <h1 class="font-display text-6xl md:text-8xl font-semibold leading-[0.95] tracking-tight max-w-4xl">
      A short, sharp{" "}
      <span class="italic" style="color: var(--color-accent)">promise</span>{" "}
      about what you do.
    </h1>
    <p class="mt-8 text-lg md:text-xl text-neutral-400 max-w-xl leading-relaxed">
      The supporting line. One sentence that explains who it's for and why
      they'd care, without resorting to jargon.
    </p>
    <div class="mt-10 flex flex-wrap gap-4">
      <a
        href="#cta"
        class="px-6 py-3 rounded-full bg-white text-black font-medium hover:bg-neutral-200 transition-colors"
      >
        Start free
      </a>
      <a
        href="#features"
        class="px-6 py-3 rounded-full border border-white/20 hover:bg-white/5 transition-colors"
      >
        See how it works
      </a>
    </div>
  </div>
</section>
