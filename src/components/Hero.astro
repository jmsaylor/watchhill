---
// ─────────────────────────────────────────────────────────────────────────
// FEATURED POST — to feature a different article, edit just this block.
// Everything below is presentation; this is the content.
// ─────────────────────────────────────────────────────────────────────────
const featured = {
  href: "/blog/june-in-watch-hill",
  kicker: "Now Live · Early Summer 2026",
  title: "June in Watch Hill",
  subtitle:
    "The village is fully open, water is warming, and the biggest free cultural event of the year happens on June 20. A local's guide to early summer — including the events worth planning around and why June is the quietly best time to visit before the July peak.",
  meta: [
    "June 20 — Summer Pops at Wilcox Park",
    "Music on the Hill — all month",
    "Lower rates than July & August",
  ],
  readingTime: "9 min read",
};

const secondary = [
  {
    href: "/blog/best-things-to-do-in-watch-hill-ri",
    tag: "Start Here",
    title: "15 Best Things to Do in Watch Hill",
  },
  {
    href: "/blog/where-to-stay-watch-hill",
    tag: "Hotel Guide",
    title: "Where to Stay in Watch Hill",
  },
  {
    href: "/blog/watch-hill-vs-newport",
    tag: "Comparison",
    title: "Watch Hill vs Newport: Which to Visit?",
  },
];
---

<section class="hero">
  <div class="hero-shell">
    <div class="hero-grid">
      <div class="hero-text">
        <a href={featured.href} class="featured-link" aria-label={featured.title}>
          <p class="kicker">{featured.kicker}</p>
          <h1 class="hero-title">{featured.title}</h1>
          <p class="hero-sub">{featured.subtitle}</p>

          <ul class="meta-list">
            {featured.meta.map((bullet) => (<li>{bullet}</li>))}
          </ul>

          <p class="hero-cta">
            <span class="cta-text">Read the full guide</span>
            <span class="cta-arrow">→</span>
            <span class="cta-time">· {featured.readingTime}</span>
          </p>
        </a>
      </div>

      <div class="hero-art" aria-hidden="true">
        <div class="art-frame">
          <svg viewBox="0 0 400 500" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
            <defs>
              <linearGradient id="sky-june" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#fef4d8"/>
                <stop offset="50%" stop-color="#f9d99a"/>
                <stop offset="100%" stop-color="#e8a572"/>
              </linearGradient>
              <linearGradient id="water-june" x1="0" y1="0" x2="0" y2="1">
                <stop offset="0%" stop-color="#c98558"/>
                <stop offset="50%" stop-color="#5d7c89"/>
                <stop offset="100%" stop-color="#2c4d5e"/>
              </linearGradient>
              <radialGradient id="sun-glow" cx="50%" cy="50%" r="50%">
                <stop offset="0%" stop-color="#fff5d6" stop-opacity="0.9"/>
                <stop offset="50%" stop-color="#f9d99a" stop-opacity="0.4"/>
                <stop offset="100%" stop-color="#f9d99a" stop-opacity="0"/>
              </radialGradient>
            </defs>

            <rect width="400" height="500" fill="url(#sky-june)"/>
            <circle cx="200" cy="240" r="110" fill="url(#sun-glow)"/>
            <circle cx="200" cy="240" r="32" fill="#fffaeb" opacity="0.9"/>
            <circle cx="200" cy="240" r="22" fill="#fff5d6"/>

            <path d="M 0 295 Q 100 285 200 290 T 400 295 L 400 305 L 0 305 Z" fill="#1d3f3d" opacity="0.45"/>

            <rect y="295" width="400" height="135" fill="url(#water-june)" opacity="0.92"/>

            <ellipse cx="200" cy="320" rx="60" ry="3" fill="#fff5d6" opacity="0.6"/>
            <ellipse cx="200" cy="335" rx="50" ry="2" fill="#fff5d6" opacity="0.5"/>
            <ellipse cx="200" cy="350" rx="40" ry="2" fill="#fff5d6" opacity="0.4"/>
            <ellipse cx="200" cy="365" rx="30" ry="1.5" fill="#fff5d6" opacity="0.3"/>
            <ellipse cx="200" cy="380" rx="22" ry="1" fill="#fff5d6" opacity="0.25"/>

            <line x1="40" y1="345" x2="100" y2="345" stroke="#fbf8f1" stroke-width="0.5" opacity="0.4"/>
            <line x1="310" y1="370" x2="370" y2="370" stroke="#fbf8f1" stroke-width="0.5" opacity="0.4"/>
            <line x1="60" y1="395" x2="120" y2="395" stroke="#fbf8f1" stroke-width="0.5" opacity="0.4"/>

            <rect y="420" width="400" height="80" fill="#f3ede0"/>
            <rect y="420" width="400" height="80" fill="#b8924a" opacity="0.18"/>

            <g transform="translate(140, 320)" opacity="0.55">
              <line x1="0" y1="-26" x2="0" y2="6" stroke="#1a1d24" stroke-width="0.8"/>
              <polygon points="0,-24 0,3 13,3" fill="#1a1d24" opacity="0.55"/>
              <path d="M -8 6 L 8 6 L 6 9 L -6 9 Z" fill="#1a1d24"/>
            </g>

            <g transform="translate(330, 200)">
              <path d="M -70 105 Q 0 65 70 105 L 70 110 L -70 110 Z" fill="#1d3f3d" opacity="0.55"/>
              <rect x="-7" y="55" width="14" height="50" fill="#fbf8f1" opacity="0.95"/>
              <rect x="-9" y="46" width="18" height="9" fill="#1a1d24"/>
              <rect x="-5" y="36" width="10" height="10" fill="#b8924a"/>
              <circle cx="0" cy="41" r="14" fill="#b8924a" opacity="0.3"/>
              <polygon points="-3,36 3,36 0,29" fill="#1a1d24"/>
            </g>
          </svg>
        </div>
        <p class="art-caption">Sunset at Watch Hill Lighthouse, early June</p>
      </div>
    </div>

    <div class="secondary">
      <p class="secondary-label">More to explore</p>
      <div class="secondary-grid">
        {secondary.map((post) => (
          <a class="secondary-card" href={post.href}>
            <p class="sc-tag">{post.tag}</p>
            <h3>{post.title}</h3>
            <span class="sc-arrow">Read →</span>
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  :root {
    --ink: #1a1d24;
    --ink-soft: #4a5061;
    --ink-muted: #7a8195;
    --paper: #fbf8f1;
    --paper-warm: #f3ede0;
    --line: #e5dfd0;
    --accent: #2c5f5d;
    --accent-deep: #1d3f3d;
    --gold: #b8924a;
    --font-display: "Fraunces", Georgia, serif;
    --font-body: "Inter Tight", -apple-system, system-ui, sans-serif;
  }

  .hero {
    background: var(--paper);
    color: var(--ink);
    font-family: var(--font-body);
    padding: 3rem 1.5rem 5rem;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: "";
    position: absolute;
    top: -120px;
    right: -120px;
    width: 480px;
    height: 480px;
    border-radius: 50%;
    background: var(--paper-warm);
    filter: blur(80px);
    opacity: 0.55;
    z-index: 0;
  }
  .hero-shell { max-width: 1200px; margin: 0 auto; position: relative; z-index: 1; }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 4rem;
    align-items: center;
    padding: 3rem 0 5rem;
    border-bottom: 1px solid var(--line);
  }

  .featured-link {
    display: block;
    text-decoration: none;
    color: inherit;
    transition: transform 0.25s ease;
  }
  .featured-link:hover { transform: translateX(2px); }
  .featured-link:hover .cta-arrow { transform: translateX(6px); }

  .kicker {
    font-family: var(--font-body);
    font-size: 0.8rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin: 0 0 1.5rem;
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }
  .kicker::before {
    content: "";
    width: 28px;
    height: 1px;
    background: var(--gold);
    display: inline-block;
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.6rem, 6vw, 4.75rem);
    line-height: 0.98;
    letter-spacing: -0.03em;
    font-weight: 600;
    margin: 0 0 1.5rem;
    color: var(--ink);
  }

  .hero-sub {
    font-size: clamp(1.05rem, 1.5vw, 1.2rem);
    line-height: 1.55;
    color: var(--ink-soft);
    margin: 0 0 2rem;
    max-width: 520px;
  }

  .meta-list {
    list-style: none;
    padding: 0 0 0 1.25rem;
    margin: 0 0 2.5rem;
    border-left: 2px solid var(--gold);
  }
  .meta-list li {
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink);
    padding: 0.4rem 0;
    letter-spacing: -0.005em;
  }
  .meta-list li + li { border-top: 1px solid var(--line); }

  .hero-cta {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    margin: 0;
    font-size: 0.92rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--accent);
  }
  .cta-arrow {
    transition: transform 0.2s ease;
    display: inline-block;
    color: var(--accent);
    font-size: 1.1rem;
  }
  .cta-time {
    color: var(--ink-muted);
    font-weight: 500;
    letter-spacing: 0.02em;
    text-transform: none;
  }

  .hero-art {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 5;
    max-width: 440px;
    justify-self: end;
  }
  .art-frame {
    width: 100%;
    height: 100%;
    border-radius: 6px;
    overflow: hidden;
    background: var(--paper-warm);
    box-shadow: 0 1px 0 rgba(26, 29, 36, 0.06), 0 18px 50px -20px rgba(26, 29, 36, 0.18);
  }
  .art-frame svg { width: 100%; height: 100%; display: block; }
  .art-caption {
    position: absolute;
    bottom: -2rem;
    right: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.85rem;
    color: var(--ink-muted);
    margin: 0;
    letter-spacing: -0.005em;
  }

  .secondary { padding: 4rem 0 0; }
  .secondary-label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: 600;
    margin: 0 0 1.5rem;
  }
  .secondary-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }
  .secondary-card {
    background: white;
    border: 1px solid var(--line);
    padding: 1.5rem 1.5rem 1.25rem;
    border-radius: 4px;
    text-decoration: none;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, border-color 0.2s ease;
    position: relative;
  }
  .secondary-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
  }
  .secondary-card:hover .sc-arrow { color: var(--accent-deep); }

  .sc-tag {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    margin: 0 0 0.75rem;
  }
  .secondary-card h3 {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.015em;
    margin: 0 0 1.25rem;
    flex: 1;
  }
  .sc-arrow {
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
    color: var(--accent);
    transition: color 0.15s ease;
  }

  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 2.5rem;
      padding: 2rem 0 3rem;
    }
    .hero-art {
      order: -1;
      max-width: 360px;
      justify-self: start;
      aspect-ratio: 5 / 4;
    }
    .art-caption { position: static; margin-top: 0.6rem; }
  }
  @media (max-width: 640px) {
    .hero { padding: 2rem 1.25rem 3.5rem; }
    .hero-title { font-size: clamp(2.2rem, 9vw, 3rem); }
    .meta-list { padding-left: 1rem; }
  }
</style>
