---
const links = [
  { href: "/plan", label: "Plan Your Trip" },
  { href: "/do", label: "Things to Do" },
  { href: "/stay", label: "Where to Stay" },
  { href: "/eat", label: "Eat & Drink" },
  { href: "/day-trips", label: "Day Trips" },
];
---

<nav class="nav">
  <div class="nav-inner">
    <a href="/" class="brand">
      Watch Hill <span class="brand-mark">·</span> Guide
    </a>

    <ul class="nav-links">
      {
        links.map((l) => (
          <li>
            <a href={l.href}>{l.label}</a>
          </li>
        ))
      }
    </ul>

    <button class="menu-toggle" aria-label="Open menu" aria-expanded="false">
      <span></span>
      <span></span>
      <span></span>
    </button>
  </div>

  <!-- Mobile drawer -->
  <div class="mobile-drawer">
    <ul>
      {
        links.map((l) => (
          <li>
            <a href={l.href}>{l.label}</a>
          </li>
        ))
      }
    </ul>
  </div>
  <a data-formkit-toggle="c4cde41741" href="https://watch-hill-guide.kit.com/c4cde41741">Get exclusive guides</a>
</nav>

<script>
  const toggle = document.querySelector(".menu-toggle");
  const drawer = document.querySelector(".mobile-drawer");
  const nav = document.querySelector(".nav");

  toggle?.addEventListener("click", () => {
    const open = nav?.classList.toggle("open");
    toggle.setAttribute("aria-expanded", String(open));
  });
</script>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(251, 248, 241, 0.92);
    backdrop-filter: saturate(140%) blur(12px);
    -webkit-backdrop-filter: saturate(140%) blur(12px);
    border-bottom: 1px solid #e5dfd0;
    font-family: "Inter Tight", -apple-system, system-ui, sans-serif;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .brand {
    font-family: "Fraunces", Georgia, serif;
    font-size: 1.25rem;
    font-weight: 600;
    color: #1a1d24;
    text-decoration: none;
    letter-spacing: -0.01em;
    white-space: nowrap;
  }

  .brand-mark {
    color: #2c5f5d;
    font-weight: 400;
    margin: 0 0.15rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-links a {
    font-size: 0.92rem;
    color: #4a5061;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.15s ease;
    position: relative;
  }

  .nav-links a:hover {
    color: #2c5f5d;
  }

  .nav-links a::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -4px;
    height: 2px;
    background: #2c5f5d;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.2s ease;
  }

  .nav-links a:hover::after {
    transform: scaleX(1);
  }

  /* Hamburger */
  .menu-toggle {
    display: none;
    background: none;
    border: 0;
    padding: 0.5rem;
    cursor: pointer;
    flex-direction: column;
    gap: 5px;
    width: 32px;
  }

  .menu-toggle span {
    width: 22px;
    height: 2px;
    background: #1a1d24;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .nav.open .menu-toggle span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav.open .menu-toggle span:nth-child(2) {
    opacity: 0;
  }
  .nav.open .menu-toggle span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile drawer */
  .mobile-drawer {
    display: none;
    border-top: 1px solid #e5dfd0;
    background: #fbf8f1;
  }

  .mobile-drawer ul {
    list-style: none;
    margin: 0;
    padding: 0.5rem 0;
  }

  .mobile-drawer li {
    border-bottom: 1px solid #e5dfd0;
  }

  .mobile-drawer li:last-child {
    border-bottom: none;
  }

  .mobile-drawer a {
    display: block;
    padding: 1rem 1.5rem;
    color: #1a1d24;
    text-decoration: none;
    font-family: "Fraunces", Georgia, serif;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: -0.01em;
  }

  .mobile-drawer a:hover {
    background: #f3ede0;
  }

  /* Breakpoint */
  @media (max-width: 860px) {
    .nav-links {
      display: none;
    }

    .menu-toggle {
      display: flex;
    }

    .nav.open .mobile-drawer {
      display: block;
    }
  }
</style>
