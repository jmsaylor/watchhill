---
const links = [
  { href: "#features", label: "Features" },
  { href: "#pricing", label: "Pricing" },
  { href: "#about", label: "About" },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 backdrop-blur-md bg-white/60 border-b border-sky-100">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="font-display text-xl font-semibold tracking-tight" style="color: var(--color-deep)">
      Your<span style="color: var(--color-ocean)">/</span>brand
    </a>
    <ul class="hidden md:flex items-center gap-8 text-sm">
      {links.map((l) => (
        <li><a href={l.href} class="transition-colors" style="color: var(--color-muted)" onmouseover="this.style.color='var(--color-deep)'" onmouseout="this.style.color='var(--color-muted)'">{l.label}</a></li>
      ))}
    </ul>
    <a
      href="#cta"
      class="text-sm px-4 py-2 rounded-full font-medium text-white transition-opacity hover:opacity-90"
      style="background: var(--color-ocean)"
    >
      Get started
    </a>
  </div>
</nav>
