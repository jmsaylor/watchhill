    .m-facts dt {
      font-size: 0.68rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--ink-muted);
      font-weight: 600;
      margin: 0 0 0.2rem;
    }

    .m-facts dd {
      margin: 0;
      font-size: 0.95rem;
      color: var(--ink);
      font-family: var(--font-display);
      font-weight: 500;
      letter-spacing: -0.005em;
      line-height: 1.3;
    }

    .m-summary {
      font-size: 1.05rem;
      line-height: 1.65;
      color: var(--ink);
      margin: 0 0 1.5rem;
    }

    .m-status {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .m-status-col {
      padding: 1rem 1.25rem;
      border-radius: 0 4px 4px 0;
      font-size: 0.92rem;
      line-height: 1.5;
    }

    .m-status-col.open {
      background: var(--paper-warm);
      border-left: 3px solid var(--accent);
    }

    .m-status-col.closed {
      background: var(--paper-warm);
      border-left: 3px solid var(--rose);
    }

    .m-status-h {
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      font-weight: 700;
      margin: 0 0 0.4rem;
    }

    .m-status-col.open .m-status-h {
      color: var(--accent);
    }

    .m-status-col.closed .m-status-h {
      color: var(--rose);
    }

    .m-status-col p:not(.m-status-h) {
      margin: 0;
      color: var(--ink-soft);
