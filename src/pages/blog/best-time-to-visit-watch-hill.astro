    .cal strong {
      color: var(--ink);
      font-weight: 600;
    }

    /* ── STAY BLOCK ───────────────────────────────────── */
    .stay {
      background: var(--paper-warm);
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
      padding: 4rem 1.5rem;
      margin: 4rem 0;
