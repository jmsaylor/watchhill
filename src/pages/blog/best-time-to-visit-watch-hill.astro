    .stay h2 {
      font-family: var(--font-display);
      font-size: clamp(1.75rem, 3vw, 2.3rem);
      line-height: 1.1;
      letter-spacing: -0.02em;
      font-weight: 600;
      margin: 0 0 1rem;
