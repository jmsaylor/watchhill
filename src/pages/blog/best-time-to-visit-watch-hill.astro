    .stay-inner {
      max-width: 1080px;
      margin: 0 auto;
    }

    .s-tag {
      font-size: 0.75rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 600;
      margin: 0 0 0.75rem;
