---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import StubPost from "../../components/StubPost.astro";

const title = "Affordable Places to Stay Near Watch Hill";
const description = "Budget hotels and rentals under $250/night in Westerly, Misquamicut, and Pawcatuck — close to Watch Hill without the luxury price.";
const preview = "Real options under $250/night in Westerly, Misquamicut, and Pawcatuck. None require you to sacrifice the experience.";

const related = [
  {"href":"/blog/where-to-stay-watch-hill","title":"Where to Stay in Watch Hill","tag":"Hotels"},
  {"href":"/blog/best-things-to-do-in-watch-hill-ri","title":"15 Best Things to Do in Watch Hill","tag":"Activities"},
  {"href":"/blog/is-watch-hill-worth-visiting","title":"Is Watch Hill Worth Visiting?","tag":"Planning"},
  {"href":"/blog/best-restaurants-watch-hill","title":"15 Best Restaurants in Watch Hill & Westerly","tag":"Food"},
];
---

<Base title={`${title} | Watch Hill Guide`} description={description} noindex={true}>
  <Nav />
  <StubPost
    title={title}
    hubLabel="Where to Stay"
    hubHref="/stay"
    preview={preview}
    related={related}
  />
</Base>
