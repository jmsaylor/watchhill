---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import AttractionPost from "../../components/AttractionPost.astro";
import { affiliates } from "../../data/affiliates";

const title =
  "A Day at Foxwoods Casino from Watch Hill (2026 Local's Guide)";
const description =
  "How to spend a day at Foxwoods Resort Casino from Watch Hill, RI — gambling, the Mashantucket Pequot Museum, dining, concerts, and the hidden details locals know but tourists miss.";

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TouristAttraction",
  name: "Foxwoods Resort Casino",
  description: "The largest resort casino in North America, owned and operated by the Mashantucket Pequot Tribal Nation in Mashantucket, Connecticut.",
  address: {
    "@type": "PostalAddress",
    streetAddress: "350 Trolley Line Boulevard",
    addressLocality: "Mashantucket",
    addressRegion: "CT",
    postalCode: "06338",
    addressCountry: "US",
  },
};

const props = {
  kicker: "Day Trip · 30 Minutes North of Watch Hill",
  title: "A Day at ",
  titleEm: "Foxwoods Casino",
  titleTail: " from Watch Hill",
