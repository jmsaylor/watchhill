  "@context": "https://schema.org",
  "@type": "Article",
  headline: "How Many Days Do You Need in Watch Hill?",
};

const props = {
  kicker: "Trip Planning · Local Guide",
  title: "How Many Days Do You Need in ",
  titleEm: "Watch Hill",
  titleTail: "?",
  subtitle: "Two days for the headline experience. Three days for a comfortable trip. Five to seven days for a Watch Hill-based vacation that includes Mystic, Newport, or Block Island. Here's the honest breakdown of what fits in each.",
  readingTime: "7 min read",
  verdict: "<strong>Three days is the right length for most travelers.</strong> Watch Hill village itself is small enough to see in one day. The surrounding region (Mystic, Newport, Block Island, Charlestown beaches) is where additional days pay off. Single-day Watch Hill trips work for a quick taste but miss most of what makes the area worth visiting.",
  quickFacts: [
    { label: "Day trip", value: "Possible but rushed" },
    { label: "2 days", value: "Headline experience" },
    { label: "3 days", value: "Comfortable, well-paced" },
