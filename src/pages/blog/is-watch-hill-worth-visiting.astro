    td {
      padding: 1rem 1.25rem;
      border-bottom: 1px solid var(--line);
      color: var(--ink-soft);
    }

    tbody tr:last-child td {
      border-bottom: none;
    }

    tbody tr.highlight {
      background: var(--paper-warm);
    }

    tbody tr.highlight td {
      color: var(--ink);
      font-weight: 500;
    }

    tbody tr.highlight strong {
      color: var(--accent);
    }

    /* ── DECISION GRID (Visit If / Skip If) ───────────── */
    .decide {
      max-width: 1080px;
      margin: 4rem auto;
      padding: 0 1.5rem;
    }

    .decide-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 1.5rem;
    }

    .decide-col {
      padding: 2rem;
      border-radius: 4px;
      background: white;
      border: 1px solid var(--line);
    }

    .decide-col.yes {
      border-left: 4px solid var(--accent);
    }

    .decide-col.no {
      border-left: 4px solid var(--rose);
    }

    .decide-tag {
      font-family: var(--font-display);
      font-size: 1.25rem;
      font-weight: 600;
      letter-spacing: -0.01em;
      margin: 0 0 1.25rem;
      color: var(--ink);
    }

    .decide-col ul {
      list-style: none;
      padding: 0;
      margin: 0;
    }

    .decide-col li {
      padding: 0.75rem 0;
      padding-left: 1.75rem;
      position: relative;
      color: var(--ink-soft);
      font-size: 0.95rem;
      line-height: 1.5;
      border-bottom: 1px solid var(--line);
    }

    .decide-col li:last-child {
      border-bottom: none;
    }

    .decide-col li::before {
      position: absolute;
      left: 0;
      top: 0.75rem;
      font-weight: 600;
      font-size: 1.1rem;
      line-height: 1.3;
    }

    .decide-col.yes li::before {
      content: "✓";
      color: var(--accent);
    }

    .decide-col.no li::before {
      content: "×";
      color: var(--rose);
    }

    /* ── RECOMMENDATION (affiliate block) ─────────────── */
    .rec {
      background: var(--paper-warm);
      padding: 4rem 1.5rem;
      margin: 4rem 0;
      border-top: 1px solid var(--line);
      border-bottom: 1px solid var(--line);
    }

    .rec-inner {
      max-width: 1080px;
      margin: 0 auto;
    }

    .rec-tag {
      font-size: 0.75rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 600;
      margin: 0 0 0.75rem;
    }

    .rec h2 {
      font-family: var(--font-display);
      font-size: clamp(1.75rem, 3vw, 2.4rem);
      line-height: 1.1;
      letter-spacing: -0.015em;
      font-weight: 600;
      margin: 0 0 1rem;
    }

    .rec-intro {
      max-width: 600px;
      color: var(--ink-soft);
      margin: 0 0 2.5rem;
    }

    .rec-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 1rem;
    }

    .rec-card {
      background: white;
      border: 1px solid var(--line);
      padding: 1.75rem;
      border-radius: 4px;
      display: flex;
      flex-direction: column;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .rec-card:hover {
      transform: translateY(-2px);
      box-shadow: 0 12px 30px rgba(26, 29, 36, 0.08);
    }

    .rec-card-tag {
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 600;
      margin: 0 0 0.5rem;
    }

    .rec-card h3 {
      font-family: var(--font-display);
      font-size: 1.4rem;
      margin: 0 0 0.75rem;
      font-weight: 600;
      letter-spacing: -0.01em;
    }

    .rec-card p:not(.rec-card-tag) {
      font-size: 0.95rem;
      color: var(--ink-soft);
      margin: 0 0 1.25rem;
      flex: 1;
    }

    .rec-cta {
      align-self: flex-start;
      font-weight: 600;
      color: var(--accent);
      text-decoration: none;
      border-bottom: 1px solid var(--accent);
      padding-bottom: 2px;
      transition: color 0.15s ease;
    }

    .rec-cta:hover {
      color: var(--accent-deep);
    }

    /* ── FINALE ───────────────────────────────────────── */
    .finale {
      padding: 0 1.5rem;
      margin: 4rem 0;
    }

    .finale-inner {
      max-width: 680px;
      margin: 0 auto;
      padding: 3rem;
      background: var(--ink);
      color: var(--paper);
      border-radius: 4px;
    }

    .finale-label {
      font-size: 0.75rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--gold);
      font-weight: 600;
      margin: 0 0 0.75rem;
    }

    .finale h2 {
      font-family: var(--font-display);
      font-size: clamp(1.75rem, 3vw, 2.4rem);
      line-height: 1.1;
      letter-spacing: -0.015em;
      font-weight: 600;
      margin: 0 0 1.5rem;
      color: white;
    }

    .finale p {
      font-size: 1.1rem;
      line-height: 1.7;
      color: rgba(251, 248, 241, 0.85);
      margin: 0 0 1.25rem;
    }

    .finale p:last-child {
      margin-bottom: 0;
    }

    /* ── FAQ ──────────────────────────────────────────── */
    .faq {
      max-width: 760px;
      margin: 4rem auto;
      padding: 0 1.5rem;
    }

    .faq-item {
      border-bottom: 1px solid var(--line);
      padding: 1.25rem 0;
    }

    .faq-item summary {
      font-family: var(--font-display);
      font-size: 1.15rem;
      font-weight: 600;
      cursor: pointer;
      color: var(--ink);
      list-style: none;
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      letter-spacing: -0.005em;
    }

    .faq-item summary::-webkit-details-marker {
      display: none;
    }

    .faq-item summary::after {
      content: "+";
      font-size: 1.5rem;
      color: var(--accent);
      font-weight: 400;
      transition: transform 0.2s ease;
      flex-shrink: 0;
    }

    .faq-item[open] summary::after {
      content: "−";
    }

    .faq-item p {
      margin: 1rem 0 0;
      color: var(--ink-soft);
      font-size: 1rem;
      line-height: 1.6;
    }

    /* ── RELATED ──────────────────────────────────────── */
    .related {
      max-width: 1080px;
      margin: 4rem auto 0;
      padding: 3rem 1.5rem 0;
      border-top: 1px solid var(--line);
    }

    .related-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1rem;
    }

    .related-card {
      display: block;
      background: white;
      border: 1px solid var(--line);
      padding: 1.5rem;
      text-decoration: none;
      color: var(--ink);
      border-radius: 4px;
      transition: transform 0.2s ease, border-color 0.2s ease;
    }

    .related-card:hover {
      transform: translateY(-2px);
      border-color: var(--accent);
    }

    .related-tag {
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--accent);
      font-weight: 600;
      margin: 0 0 0.75rem;
    }

    .related-card h3 {
      font-family: var(--font-display);
      font-size: 1.15rem;
      font-weight: 600;
      margin: 0;
      line-height: 1.25;
      letter-spacing: -0.01em;
    }

    /* ── MOBILE ───────────────────────────────────────── */
    @media (max-width: 640px) {
      .hero {
        padding: 3.5rem 1.25rem 2.5rem;
      }

      .finale-inner {
        padding: 2rem 1.5rem;
      }

      .verdict {
        padding: 2rem 1.25rem;
      }
    }
  </style>
</Base>
