---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import StubPost from "../../components/StubPost.astro";

const title = "Best Restaurants on the Misquamicut Beach Strip";
const description = "Paddy's Beach Club, Andrea's, and the casual seaside restaurants locals recommend after a beach day in Misquamicut, RI.";
const preview = "Paddy's Beach Club, Andrea's, and the casual seaside restaurants locals recommend after a beach day on the Misquamicut strip.";

const related = [
  {"href":"/blog/best-restaurants-watch-hill","title":"15 Best Restaurants in Watch Hill & Westerly","tag":"Food"},
  {"href":"/blog/best-things-to-do-in-watch-hill-ri","title":"15 Best Things to Do in Watch Hill","tag":"Activities"},
  {"href":"/blog/where-to-stay-watch-hill","title":"Where to Stay in Watch Hill","tag":"Hotels"},
  {"href":"/blog/memorial-day-watch-hill","title":"Memorial Day in Watch Hill & Westerly","tag":"Seasonal"},
];
---

<Base title={`${title} | Watch Hill Guide`} description={description} noindex={true}>
  <Nav />
  <StubPost
    title={title}
    hubLabel="Eat & Drink"
    hubHref="/eat"
    preview={preview}
    related={related}
  />
</Base>
