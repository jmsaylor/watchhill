const jsonLd = {
  "@context": "https://schema.org",
  "@type": "TravelGuide",
  name: "Mystic, Connecticut Day Trip Guide",
  description: "Complete day-trip itinerary for Mystic, CT from the Watch Hill / Westerly, RI area.",
  about: {
    "@type": "Place",
    name: "Mystic, Connecticut",
    address: {
      "@type": "PostalAddress",
      addressLocality: "Mystic",
      addressRegion: "CT",
