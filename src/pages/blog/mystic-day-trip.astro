---
import Base from "../../layouts/Base.astro";
import Nav from "../../components/Nav.astro";
import StubPost from "../../components/StubPost.astro";

const title = "A Perfect Day in Mystic, CT from Watch Hill";
const description = "How to spend a perfect day in Mystic, Connecticut from Watch Hill — Mystic Seaport, the Aquarium, downtown, and where to eat.";
const preview = "Mystic Seaport, Mystic Aquarium, and the historic downtown — the full day-trip itinerary, including the restaurants worth the drive.";

const related = [
  {"href":"/blog/day-trips-from-watch-hill","title":"10 Best Day Trips from Watch Hill","tag":"Day Trips"},
  {"href":"/blog/best-things-to-do-in-watch-hill-ri","title":"15 Best Things to Do in Watch Hill","tag":"Activities"},
  {"href":"/blog/where-to-stay-watch-hill","title":"Where to Stay in Watch Hill","tag":"Hotels"},
  {"href":"/blog/best-restaurants-watch-hill","title":"15 Best Restaurants in Watch Hill & Westerly","tag":"Food"},
];
---

<Base title={`${title} | Watch Hill Guide`} description={description} noindex={true}>
  <Nav />
  <StubPost
    title={title}
    hubLabel="Day Trips"
    hubHref="/day-trips"
    preview={preview}
    related={related}
  />
</Base>
