  name: "The Olympia Tea Room",
  description: "Historic American bistro on Bay Street in Watch Hill, RI, operating since 1916.",
  address: {
    "@type": "PostalAddress",
    streetAddress: "74 Bay Street",
    addressLocality: "Watch Hill",
    addressRegion: "RI",
    postalCode: "02891",
    addressCountry: "US",
  },
  telephone: "+14013488211",
  servesCuisine: "American",
  priceRange: "$$$",
};

const props = {
  kicker: "Bay Street · Since 1916",
  title: "110 Years at ",
  titleEm: "Olympia Tea Room",
