const title = "Olympia Tea Room Review: 110 Years on Bay Street (2026 Local's Guide)";
const description = "An honest review of the Olympia Tea Room in Watch Hill, RI — operating since 1916, run by the Felber family since 1980. What to order, when to go, and why it's the most iconic restaurant on Bay Street.";

const jsonLd = {
  "@context": "https://schema.org",
