---
import Base from "../layouts/Base.astro";
import Nav from "../components/Nav.astro";

const title = "Plan Your Trip to Watch Hill, RI | Watch Hill Guide";
const description =
  "Everything you need to plan a trip to Watch Hill, Rhode Island — when to visit, how many days you need, getting there, and whether it's right for you.";

// Articles in this hub. Easy to add to — just push to the array.
// Order matters: top of page = highest-priority article for new visitors.
const featured = {
  href: "/blog/is-watch-hill-worth-visiting",
  tag: "Start Here",
  title: "Is Watch Hill, Rhode Island Worth Visiting?",
  description:
    "The honest answer — including who'll love it, who won't, and how it stacks up against Newport, the Hamptons, and the Cape.",
  readTime: "9 min read",
};

const articles = [
  {
    href: "/blog/best-time-to-visit-watch-hill",
    tag: "Timing",
    title: "Best Time to Visit Watch Hill (Month-by-Month)",
    description:
      "When to come for swimming, when to come for solitude, and what's actually open in each season.",
    readTime: "7 min",
  },
  {
    href: "/blog/how-many-days-watch-hill",
    tag: "Timing",
    title: "How Many Days Do You Need in Watch Hill?",
    description:
      "A weekend, a long weekend, or a full week — here's how to match your trip length to your travel style.",
    readTime: "5 min",
  },
  {
    href: "/blog/getting-to-watch-hill",
    tag: "Logistics",
    title: "How to Get to Watch Hill from Boston, NYC, or Providence",
    description:
      "Driving times, train options, parking tips, and the local taxi situation for car-free travelers.",
    readTime: "6 min",
  },
  {
    href: "/blog/watch-hill-with-kids",
    tag: "Family",
    title: "Visiting Watch Hill with Kids: A Family Guide",
    description:
      "Why this might be the most kid-friendly upscale coastal town in New England — and the spots tailored to younger travelers.",
    readTime: "8 min",
  },
  {
    href: "/blog/watch-hill-vs-newport",
    tag: "Comparison",
    title: "Watch Hill vs Newport: Which Should You Choose?",
    description:
      "Both are Rhode Island coastal towns. They couldn't be more different. Here's how to pick.",
    readTime: "10 min",
  },
  {
    href: "/blog/watch-hill-packing-list",
    tag: "Prep",
    title: "What to Pack for a Watch Hill Trip",
    description:
      "From beach essentials to dinner attire at Ocean House — everything you actually need, nothing you don't.",
    readTime: "5 min",
  },
  {
    href: "/blog/watch-hill-weather",
    tag: "Weather",
    title: "Watch Hill Weather: A Seasonal Guide",
    description:
      "Temperatures, ocean water temps, rainfall, and what to expect by month for trip planning.",
    readTime: "4 min",
  },
  {
    href: "/blog/watch-hill-budget-guide",
    tag: "Budget",
    title: "How Much Does a Watch Hill Trip Cost?",
    description:
      "Real numbers for a 3-day trip at three different budget levels — from frugal to all-out splurge.",
    readTime: "8 min",
  },
];

// Quick-answer cards for high-frequency questions. These also rank for
// long-tail "people also ask" Google snippets.
const quickAnswers = [
  {
    q: "When does Watch Hill open for the season?",
    a: "Most shops, restaurants, and attractions open Memorial Day weekend in late May. The Flying Horse Carousel runs Memorial Day through Labor Day. Beaches are technically open year-round but lifeguards staff them from late June.",
  },
  {
    q: "Where do you fly into for Watch Hill?",
    a: "T.F. Green Airport in Providence (PVD) is closest at 50 minutes. Bradley in Hartford is 70 minutes. JFK and LaGuardia are 2.5–3 hours away. Boston Logan is 2 hours.",
  },
  {
    q: "Can you visit Watch Hill without a car?",
    a: "It's possible but not ideal. Amtrak's Northeast Corridor stops at Westerly Station, 10 minutes from Watch Hill. From there you'll need Uber, which is sparse. Plan to walk a lot once you're in the village.",
  },
  {
    q: "Is Watch Hill open in winter?",
    a: "Partially. Ocean House operates year-round with full restaurants. Most other shops and restaurants close from mid-October through April. The village in winter is beautifully quiet — but you need to plan around the closures.",
  },
];
---

<Base title={title} description={description}>
  <Nav />

  <main class="hub">
    <!-- Hero -->
    <header class="hub-hero">
      <div class="hub-hero-inner">
        <p class="kicker">Hub · Trip Planning</p>
        <h1>Plan Your Trip to Watch Hill</h1>
        <p class="lede">
          Everything you need to plan a great trip — when to come, how long to
          stay, how to get here, and what to expect. Written by a local who
          gets these questions every summer.
        </p>
      </div>
    </header>

    <!-- Featured (Start Here) -->
    <section class="featured-wrap">
      <a href={featured.href} class="featured">
        <div class="featured-text">
          <p class="featured-tag">{featured.tag}</p>
          <h2>{featured.title}</h2>
          <p class="featured-desc">{featured.description}</p>
          <p class="featured-meta">
            {featured.readTime} <span class="arrow">→</span>
          </p>
        </div>
        <div class="featured-graphic" aria-hidden="true">
          <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
            <circle cx="100" cy="100" r="80" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3"/>
            <circle cx="100" cy="100" r="50" fill="none" stroke="currentColor" stroke-width="1" opacity="0.5"/>
            <circle cx="100" cy="100" r="20" fill="currentColor"/>
            <line x1="100" y1="10" x2="100" y2="30" stroke="currentColor" stroke-width="1.5"/>
            <line x1="100" y1="170" x2="100" y2="190" stroke="currentColor" stroke-width="1.5"/>
            <line x1="10" y1="100" x2="30" y2="100" stroke="currentColor" stroke-width="1.5"/>
            <line x1="170" y1="100" x2="190" y2="100" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
      </a>
    </section>

    <!-- Articles grid -->
    <section class="articles">
      <div class="section-head">
        <h2>Planning Guides</h2>
        <p>Pick what you need. Skip what you don't.</p>
      </div>

      <div class="articles-grid">
        {
          articles.map((a) => (
            <a href={a.href} class="article-card">
              <p class="card-tag">{a.tag}</p>
              <h3>{a.title}</h3>
              <p class="card-desc">{a.description}</p>
              <p class="card-meta">
                {a.readTime} <span class="arrow">→</span>
              </p>
            </a>
          ))
        }
      </div>
    </section>

    <!-- Quick Answers (FAQ-style for SEO snippets) -->
    <section class="quick">
      <div class="section-head">
        <h2>Quick Answers</h2>
        <p>The questions visitors ask most often.</p>
      </div>

      <div class="quick-grid">
        {
          quickAnswers.map((qa) => (
            <div class="quick-card">
              <h3>{qa.q}</h3>
              <p>{qa.a}</p>
            </div>
          ))
        }
      </div>
    </section>

    <!-- Cross-hub navigation -->
    <section class="hubs-next">
      <p class="next-label">Continue Planning</p>
      <div class="hubs-grid">
        <a href="/do" class="hub-link">
          <h3>Things to Do</h3>
          <p>Beaches, the carousel, the lighthouse, boat tours.</p>
        </a>
        <a href="/stay" class="hub-link">
          <h3>Where to Stay</h3>
          <p>Ocean House, Weekapaug, vacation rentals.</p>
        </a>
        <a href="/eat" class="hub-link">
          <h3>Eat &amp; Drink</h3>
          <p>Restaurants, ice cream, breweries, brunch spots.</p>
        </a>
        <a href="/day-trips" class="hub-link">
          <h3>Day Trips</h3>
          <p>Mystic, Stonington, Newport, Block Island.</p>
        </a>
      </div>
    </section>
  </main>
</Base>

<style>
  :root {
    --ink: #1a1d24;
    --ink-soft: #4a5061;
    --ink-muted: #7a8195;
    --paper: #fbf8f1;
    --paper-warm: #f3ede0;
    --line: #e5dfd0;
    --accent: #2c5f5d;
    --accent-deep: #1d3f3d;
    --gold: #b8924a;
    --font-display: "Fraunces", Georgia, serif;
    --font-body: "Inter Tight", -apple-system, system-ui, sans-serif;
  }

  .hub {
    background: var(--paper);
    color: var(--ink);
    font-family: var(--font-body);
    font-size: 17px;
    line-height: 1.6;
    padding-bottom: 6rem;
  }

  .hub *,
  .hub *::before,
  .hub *::after {
    box-sizing: border-box;
  }

  /* ── HERO ─────────────────────────────────────────── */
  .hub-hero {
    background: linear-gradient(180deg, var(--paper-warm) 0%, var(--paper) 100%);
    padding: 5rem 1.5rem 4rem;
    border-bottom: 1px solid var(--line);
  }

  .hub-hero-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .kicker {
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    margin: 0 0 1.25rem;
  }

  .hub-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 5.5vw, 4rem);
    line-height: 1.02;
    letter-spacing: -0.025em;
    font-weight: 600;
    margin: 0 0 1.25rem;
  }

  .lede {
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 0;
    max-width: 600px;
  }

  /* ── FEATURED (Start Here) ────────────────────────── */
  .featured-wrap {
    max-width: 1080px;
    margin: 4rem auto;
    padding: 0 1.5rem;
  }

  .featured {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2rem;
    background: var(--ink);
    color: var(--paper);
    padding: 3rem;
    border-radius: 6px;
    text-decoration: none;
    align-items: center;
    transition: transform 0.2s ease;
    overflow: hidden;
  }

  .featured:hover {
    transform: translateY(-3px);
  }

  .featured:hover .arrow {
    transform: translateX(4px);
  }

  .featured-tag {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--gold);
    font-weight: 600;
    margin: 0 0 0.75rem;
  }

  .featured h2 {
    font-family: var(--font-display);
    font-size: clamp(1.6rem, 3.5vw, 2.3rem);
    line-height: 1.12;
    letter-spacing: -0.02em;
    font-weight: 600;
    margin: 0 0 1rem;
    color: white;
  }

  .featured-desc {
    font-size: 1.05rem;
    color: rgba(251, 248, 241, 0.78);
    margin: 0 0 1.5rem;
    max-width: 540px;
  }

  .featured-meta {
    margin: 0;
    font-size: 0.85rem;
    letter-spacing: 0.05em;
    color: var(--gold);
    text-transform: uppercase;
    font-weight: 600;
  }

  .featured-graphic {
    width: 160px;
    height: 160px;
    color: var(--gold);
    opacity: 0.65;
  }

  .featured-graphic svg {
    width: 100%;
    height: 100%;
  }

  .arrow {
    display: inline-block;
    transition: transform 0.2s ease;
    margin-left: 0.25rem;
  }

  /* ── SECTION HEAD ─────────────────────────────────── */
  .section-head {
    max-width: 760px;
    margin: 0 auto 2.5rem;
  }

  .section-head h2 {
    font-family: var(--font-display);
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    line-height: 1.1;
    letter-spacing: -0.02em;
    font-weight: 600;
    margin: 0 0 0.5rem;
  }

  .section-head p {
    color: var(--ink-soft);
    margin: 0;
  }

  /* ── ARTICLES GRID ────────────────────────────────── */
  .articles {
    max-width: 1080px;
    margin: 0 auto 4rem;
    padding: 0 1.5rem;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }

  .article-card {
    background: white;
    border: 1px solid var(--line);
    border-radius: 4px;
    padding: 1.75rem;
    text-decoration: none;
    color: var(--ink);
    display: flex;
    flex-direction: column;
    transition: transform 0.2s ease, border-color 0.2s ease;
    position: relative;
  }

  .article-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent);
  }

  .article-card:hover .arrow {
    transform: translateX(4px);
  }

  .card-tag {
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
    margin: 0 0 0.75rem;
  }

  .article-card h3 {
    font-family: var(--font-display);
    font-size: 1.25rem;
    line-height: 1.2;
    letter-spacing: -0.015em;
    font-weight: 600;
    margin: 0 0 0.75rem;
    color: var(--ink);
  }

  .card-desc {
    font-size: 0.95rem;
    color: var(--ink-soft);
    margin: 0 0 1.25rem;
    flex: 1;
    line-height: 1.5;
  }

  .card-meta {
    font-size: 0.78rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-muted);
    font-weight: 600;
    margin: 0;
  }

  /* ── QUICK ANSWERS ────────────────────────────────── */
  .quick {
    background: var(--paper-warm);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 4rem 1.5rem;
    margin-bottom: 4rem;
  }

  .quick .section-head {
    margin-left: auto;
    margin-right: auto;
  }

  .quick-grid {
    max-width: 1080px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .quick-card {
    background: white;
    padding: 1.75rem;
    border-radius: 4px;
    border: 1px solid var(--line);
  }

  .quick-card h3 {
    font-family: var(--font-display);
    font-size: 1.1rem;
    line-height: 1.25;
    letter-spacing: -0.01em;
    font-weight: 600;
    margin: 0 0 0.75rem;
  }

  .quick-card p {
    font-size: 0.95rem;
    color: var(--ink-soft);
    margin: 0;
    line-height: 1.5;
  }

  /* ── HUBS NEXT (cross-linking) ────────────────────── */
  .hubs-next {
    max-width: 1080px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .next-label {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    color: var(--ink);
    margin: 0 0 1.5rem;
  }

  .hubs-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .hub-link {
    background: var(--paper);
    border: 1px solid var(--line);
    padding: 1.5rem;
    border-radius: 4px;
    text-decoration: none;
    color: var(--ink);
    transition: border-color 0.2s ease, transform 0.2s ease;
  }

  .hub-link:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }

  .hub-link h3 {
    font-family: var(--font-display);
    font-size: 1.15rem;
    font-weight: 600;
    margin: 0 0 0.4rem;
    letter-spacing: -0.01em;
  }

  .hub-link p {
    margin: 0;
    font-size: 0.88rem;
    color: var(--ink-soft);
    line-height: 1.4;
  }

  /* ── MOBILE ───────────────────────────────────────── */
  @media (max-width: 640px) {
    .hub-hero {
      padding: 3.5rem 1.25rem 3rem;
    }

    .featured {
      grid-template-columns: 1fr;
      padding: 2rem;
    }

    .featured-graphic {
      display: none;
    }
  }
</style>
